DATABASE_URL=postgresql+asyncpg://postgres:raja807@localhost:5432/ticketing-genie
SECRET_KEY=your-256-bit-secret-key-here-change-in-production
ALGORITHM=HS256

# Auth Service
AUTH_SERVICE_URL=http://localhost:8001

# SLA defaults
DEFAULT_RESPONSE_MINUTES=480
DEFAULT_RESOLUTION_MINUTES=2880
DEFAULT_ESCALATION_MINUTES=120
AUTO_CLOSE_AFTER_HOURS=72

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development

# SendGrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@ticketinggenie.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

LEAD_ASSIGNMENT_TIMEOUT_SECONDS=300